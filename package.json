{
  "name": "flowm",
  "private": true,
  "version": "0.1.4",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo -F desktop dev",
    "dev:web": "pnpm --filter web dev",
    "dev:desktop": "pnpm --filter desktop dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "check-architecture": "node scripts/check-architecture.mjs",
    "check-docs": "node scripts/check-docs.mjs",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "typecheck": "turbo check-types",
    "rebuild:electron": "pnpm -F desktop exec electron-builder install-app-deps",
    "test": "pnpm run test:electron",
    "test:electron": "pnpm run rebuild:electron && ELECTRON_RUN_AS_NODE=1 apps/desktop/node_modules/.bin/electron ./node_modules/vitest/vitest.mjs run",
    "flowm-cli": "pnpm -F @barrysongdev4real/flowm-cli flowm-cli --",
    "seed:demo": "pnpm -F desktop seed:demo",
    "package": "pnpm -F desktop package",
    "install:local": "node scripts/install-local-app.mjs",
    "release": "node scripts/release.mjs",
    "dist": "pnpm -F desktop dist"
  },
  "devDependencies": {
    "@vitest/ui": "^4.0.18",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "turbo": "^2.5.4",
    "typescript": "~5.8.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.12.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  }
}
