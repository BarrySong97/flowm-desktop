#!/bin/sh
# @purpose Git pre-commit harness entry point for documentation and staged-file quality checks.
# @role    Tool-independent final guard for doc drift plus Oxlint/Oxfmt feedback before commits.
# @gotcha  Install with: git config core.hooksPath scripts/hooks && chmod +x scripts/hooks/pre-commit
set -e

node scripts/check-docs.mjs
node scripts/hooks/check-staged.mjs
