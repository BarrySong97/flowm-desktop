# Cloudflare R2 credentials for `pnpm img`.
# Copy this file to `.env` and fill the private values locally. Never commit `.env`.

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Public image origin without a trailing slash.
R2_PUBLIC_BASE=https://blogassets.4real.ink

# Object-key prefix. Defaults to `blog` when omitted.
R2_KEY_PREFIX=blog
