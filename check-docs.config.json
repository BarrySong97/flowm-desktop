{
  "sourceExts": [".js", ".mjs", ".cjs", ".ts", ".tsx", ".css"],
  "sourceRoots": [
    "apps/desktop/src",
    "apps/desktop/scripts",
    "packages/cli/src",
    "packages/api/src",
    "packages/api/tests",
    "packages/db",
    "packages/shared/src",
    "packages/ui/src",
    "scripts"
  ],
  "ignoreDirs": [
    "node_modules",
    ".git",
    "dist",
    "build",
    "coverage",
    ".turbo",
    ".cache",
    "templates"
  ],
  "nonModuleDirs": [
    "hooks",
    "scripts",
    "test",
    "tests",
    "__tests__",
    "spec",
    "bin",
    "config",
    "public",
    "assets",
    "types",
    "typings",
    "migrations"
  ],
  "headerMarker": "@purpose",
  "headerScanLines": 20,
  "docsDir": "docs",
  "ignoreFiles": [
    "apps/desktop/src/renderer/src/routeTree.gen.ts",
    "apps/desktop/src/renderer/src/vite-env.d.ts"
  ],
  "moduleAliases": {
    "main": "desktop",
    "preload": "desktop",
    "renderer": "desktop",
    "trpc": "desktop",
    "src": "db",
    "schema": "db",
    "infrastructure": "api",
    "use-cases": "api",
    "sqlite": "api",
    "cli": "cli",
    "types": "shared",
    "utils": "shared",
    "ipc": "shared",
    "components": "ui",
    "lib": "ui",
    "styles": "ui",
    "hooks": "hooks"
  }
}
